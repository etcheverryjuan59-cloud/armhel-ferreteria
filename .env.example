# ── Firebase Admin SDK ──────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=tu-proyecto-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-proyecto.iam.gserviceaccount.com
# La clave privada va entre comillas, con \n literal (Vercel lo maneja bien así)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ── Organización por defecto ─────────────────────────────────────────────────
# Se usa cuando no se envía el header X-Org-Id
DEFAULT_ORG_ID=armhel

# ── CORS ─────────────────────────────────────────────────────────────────────
# Dominio del frontend (tienda / INO). En prod: https://armhel.com.uy
# En dev podés dejarlo vacío o poner *
STORE_ORIGIN=https://armhel.com.uy

# ── Mercado Pago ──────────────────────────────────────────────────────────────
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxx
# Secreto para verificar firma de webhooks (configurar en el panel MP)
MP_WEBHOOK_SECRET=tu_secreto_webhook_mp

# ── Anthropic (asesor IA) ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ── Dev local ─────────────────────────────────────────────────────────────────
PORT=4000
